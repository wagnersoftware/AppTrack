{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "AppTrackConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=AppTrack_Local;Trusted_Connection=True;MultipleActiveResultSets=True;"
  },
  "EmailSettings": {
    "ApiKey": "",
    "FromAddress": "no-reply@apptrack.com",
    "FromName": "Apptrack Management System"
  },
  "KeyVaultUri": "",
  "AzureAd": {
    "Instance": "<instance>",
    "TenantId": "<tenant-id>",
    "ClientId": "<api-client-id>",
    "Audience": "<api-client-id>"
  },
  "OpenAiSettings": {
    "ApiUrl": "https://api.openai.com/v1/chat/completions",
    "TimeoutInSeconds": 90,
    "ApiKey": "replace-with-user-secret",
    "MaxTokens": 1000
  },
  "AzureStorageSettings": {
    "ServiceUrl": "",
    "ContainerName": ""
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost:7042"
  ]
}
