<MudDialog Class="apptrack-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
            Register
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      Label="Username"
                      Value="_model.UserName"
                      ValueChanged="@((string v) => OnUsernameChanged(v))"
                      Error="@ModelValidator.Errors.ContainsKey(nameof(RegistrationModel.UserName))"
                      ErrorText="@GetFirstError(nameof(RegistrationModel.UserName))"
                      Class="mb-3" />
        <MudTextField T="string"
                      Label="Password"
                      InputType="InputType.Password"
                      Value="_model.Password"
                      ValueChanged="@((string v) => OnPasswordChanged(v))"
                      Error="@ModelValidator.Errors.ContainsKey(nameof(RegistrationModel.Password))"
                      ErrorText="@GetFirstError(nameof(RegistrationModel.Password))"
                      Class="mb-3" />
        <MudTextField T="string"
                      Label="Confirm Password"
                      InputType="InputType.Password"
                      Value="_model.ConfirmPassword"
                      ValueChanged="@((string v) => OnConfirmPasswordChanged(v))"
                      Error="@ModelValidator.Errors.ContainsKey(nameof(RegistrationModel.ConfirmPassword))"
                      ErrorText="@GetFirstError(nameof(RegistrationModel.ConfirmPassword))"
                      Class="mb-1" />
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                @ErrorMessage
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit">
            Register
        </MudButton>
    </DialogActions>
</MudDialog>
