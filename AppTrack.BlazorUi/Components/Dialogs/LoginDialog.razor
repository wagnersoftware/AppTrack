<MudDialog Class="apptrack-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
            Login
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      Label="Username"
                      Value="_model.UserName"
                      ValueChanged="@((string v) => OnUsernameChanged(v))"
                      Error="@ModelValidator.Errors.ContainsKey(nameof(LoginModel.UserName))"
                      ErrorText="@GetFirstError(nameof(LoginModel.UserName))"
                      UserAttributes="UsernameAttributes"
                      Variant="Variant.Outlined"
                      Class="mb-3" />
        <MudTextField T="string"
                      Label="Password"
                      InputType="_passwordInputType"
                      Value="_model.Password"
                      ValueChanged="@((string v) => OnPasswordChanged(v))"
                      Error="@ModelValidator.Errors.ContainsKey(nameof(LoginModel.Password))"
                      ErrorText="@GetFirstError(nameof(LoginModel.Password))"
                      UserAttributes="PasswordAttributes"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordInputIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      Variant="Variant.Outlined"
                      Class="mb-1" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="OpenRegisterDialogAsync">
            Register
        </MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SubmitAsync">
            Login
        </MudButton>
    </DialogActions>
</MudDialog>
