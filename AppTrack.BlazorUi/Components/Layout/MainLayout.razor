@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">AppTrack</MudText>
        <MudSpacer />
        <MudButton Color="Color.Inherit"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.AccountCircle"
                   OnClick="OpenLoginDialogAsync">
            Login / Register
        </MudButton>
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>
