@page "/profile/setup"

<PageTitle>My Profile - AppTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudTooltip Text="Back to Job Applications">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/" Color="Color.Default" Class="mr-1" />
        </MudTooltip>
        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2" Color="Color.Primary" />
        <MudText Typo="Typo.h5">My Profile</MudText>
    </MudStack>

    @if (_isBusy)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
    }

    <FreelancerProfileForm @ref="_form" Model="_model" OnCvBusyChanged="@(busy => _isBusy = busy)" Disabled="_isBusy" />

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="ConfirmDeleteProfile"
                   Disabled="_isBusy">
            Delete Profile
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="Save"
                   Disabled="_isBusy">
            Save
        </MudButton>
    </MudStack>

    <MudMessageBox @ref="_deleteConfirmBox" Title="Delete Profile" CancelText="Cancel">
        <MessageContent>
            Are you sure you want to delete your profile? This will also remove your uploaded CV. This action cannot be undone.
        </MessageContent>
        <YesButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete</MudButton>
        </YesButton>
    </MudMessageBox>
</MudContainer>
